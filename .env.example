# Database
DATABASE_URL=postgresql://hirely_user:hirely_dev_2026@localhost:5434/hirely

# Auth
NEXTAUTH_URL=http://localhost:3500
NEXTAUTH_SECRET=your-secret-here

# LinkedIn OAuth 2.0
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3500/api/linkedin/callback
LINKEDIN_CANDIDATE_REDIRECT_URI=http://localhost:3500/api/public/aplicar/linkedin/callback

# LinkedIn Job Publishing
# Mode: "deeplink" (MVP), "api" (LinkedIn Talent Solutions), or "unipile" (recommended)
LINKEDIN_INTEGRATION_MODE=deeplink
# Company page ID for deep-link (found in linkedin.com/company/{slug} admin URL)
LINKEDIN_COMPANY_ID=
# API-only settings (required when LINKEDIN_INTEGRATION_MODE=api)
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_CONTRACT_ID=

# Dapta AI Voice Agent
# Obtener en: https://app.dapta.ai → Flow Studio → Tu Flow → Trigger → Public Route
DAPTA_FLOW_WEBHOOK_URL=
DAPTA_API_KEY=
DAPTA_WEBHOOK_SECRET=
DAPTA_FROM_NUMBER=

# ─── Firma Digital ────────────────────────────────────────────────────────────
# Provider activo: 'signwell' | 'docusign' | 'mock'
FIRMA_PROVIDER=mock

# SignWell (https://signwell.com — recomendado para produccion)
SIGNWELL_API_KEY=your-signwell-api-key
SIGNWELL_API_URL=https://www.signwell.com/api/v1

# DocuSign (alternativa enterprise — opcional)
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_SECRET_KEY=
# DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# URL publica de Hirely (para webhooks de firma)
APP_URL=http://localhost:3500
# En produccion: APP_URL=https://app.hirely.app

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Proyecto Resend independiente para Hirely (NO compartir con NivelLeads)
# Crear proyecto en https://resend.com → API Keys → New API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Dominio verificado en Resend para este proyecto de Hirely
RESEND_FROM_EMAIL=noreply@hirely.app

# OpenAI / Claude (Motor IA)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Google OAuth (Calendar + futuras integraciones) ─────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
# URI de callback — debe estar registrada en Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3500/api/auth/google/callback
# En produccion: GOOGLE_REDIRECT_URI=https://app.hirely.app/api/auth/google/callback

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Unipile (LinkedIn automation - recommended mode)
UNIPILE_API_URL=https://api.unipile.com
UNIPILE_API_KEY=
UNIPILE_ACCOUNT_ID=
UNIPILE_WEBHOOK_SECRET=
